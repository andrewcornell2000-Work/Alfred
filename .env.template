# Alfred configuration - copy this to .env and fill in the values you need.

# OpenAI API key.
# Used for fast classification and general chat.
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Quant plugin base URL.
# Set to the local Flask app when running plugins/quant/app.py yourself:
# QUANT_BASE_URL=http://127.0.0.1:5000
#
# Or set to a deployed cloud URL:
# QUANT_BASE_URL=https://your-quant-app.railway.app

# Claude and Codex auth is handled by CLI login:
#   claude auth login
#   codex login

# ── MCP server secrets (shared with Cursor + Claude Code by Provision-Cursor.ps1) ──
# Resolved at provision time and written to ~/.cursor/mcp.json (machine-local, never committed).
# A server is auto-skipped if its required key below is missing.

# GitHub MCP — repos, PRs, issues, code search. Create a token at:
#   https://github.com/settings/tokens  (classic: repo scope; or a fine-grained token)
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# Context7 MCP — up-to-date library docs. Optional: works without a key; a key raises rate limits.
# CONTEXT7_API_KEY=...

# Firecrawl MCP — web scraping, crawling, site mapping, structured extraction, deep research.
# Required for the firecrawl MCP server (auto-skipped if missing). Create a key at:
#   https://www.firecrawl.dev/app/api-keys
# FIRECRAWL_API_KEY=fc-...

# Tavily — live web search (direct API in Alfred, not an MCP). Free tier at https://app.tavily.com
# TAVILY_API_KEY=tvly-...

# Projects to seed on every provision (semicolon-separated repo paths).
# Each gets cursor/rules/*.mdc -> <repo>/.cursor/rules, AGENTS.md (if absent),
# and the graphify Cursor rule. Cursor only reads rules per-project, so list
# your day-to-day repos here.
# ALFRED_PROJECT_PATHS=C:\Users\you\repo1;C:\Users\you\repo2

# Supabase — project ref for the Supabase MCP (Cursor OAuth on first use).
# Dashboard -> Project Settings -> General -> Reference ID
SUPABASE_PROJECT_REF=ieahwigeexmwvggmmjzp

# Supabase Postgres direct connection (for apps/scripts — never commit real passwords).
# Replace [YOUR-PASSWORD] with your database password from Supabase Dashboard.
# SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.ieahwigeexmwvggmmjzp.supabase.co:5432/postgres
