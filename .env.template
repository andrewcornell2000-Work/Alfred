# Alfred configuration — copy this to .env and fill in any values you need.

# OpenAI API key (for GPT-4o-mini classification and general chat)
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Quant plugin — cloud URL (set this after deploying to Railway)
# Leave blank to use the local server (plugins/quant/app.py)
# QUANT_BASE_URL=https://your-quant-app.railway.app

# Claude and Codex auth is handled by CLI login — no keys needed:
#   claude login
#   codex login
