# Secrets — never commit credentials or tokens
.env
.env.*
*.env
*.key
*.secret
*.pem

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/

# Node
node_modules/
Node/
node/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editors
.vscode/
*.suo
*.user

# Compiled installer (upload to GitHub Releases, don't commit)
Alfred-Install.exe

# MCP settings — generated by installer with machine-specific paths
.claude/settings.json

# Logs (runtime only, not synced)
logs/

# Raw interaction history and personal knowledge graph — private, stays local
memory/autosave.md
memory/chat-history.json
memory/mcp-knowledge-graph.json

# Portable CLI binaries (downloaded at install time, not committed)
bin/

# Don't ignore skills/, memory/, requirements/ — those sync to GitHub

